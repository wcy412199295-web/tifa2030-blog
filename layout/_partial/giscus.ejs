<% if (theme.comments.enable && page.comments !== false) { %>
<!-- Giscus 评论系统 -->
<div class="giscus-container" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(139, 127, 212, 0.1);">
    <h3 style="font-family: 'Noto Serif SC', serif; color: var(--tifa-primary); margin-bottom: 1.5rem; font-size: 1.5rem;">
        <i class="fas fa-comments" style="margin-right: 0.5rem;"></i>留言
    </h3>
    <!-- 如果还没有配置 repoId 和 categoryId，请先阅读 GISCUS_SETUP.md -->
    <script src="https://giscus.app/client.js"
        data-repo="wcy412199295-web/tifa2030-blog"
        data-repo-id="<%= theme.comments.giscus.repoId %>"
        data-category="Announcements"
        data-category-id="<%= theme.comments.giscus.categoryId %>"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="light"
        data-lang="zh-CN"
        data-loading="lazy"
        crossorigin="anonymous"
        async>
    </script>
</div>
<% } %>
